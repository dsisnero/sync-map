# Local Crystal cache
.crystal-cache/

# Temporary working artifacts
temp/

# Dependency lock (libraries don't need it)
/shard.lock

# Shards dependency directories
/lib/
/.shards/

# Compiled binaries
/bin/
*.dwarf

# Local agent/tool settings
.claude/
.lattice-cache/

# macOS metadata (AppleDouble + Finder)
._*
.DS_Store

# Worktree directories
sync-map.*/
